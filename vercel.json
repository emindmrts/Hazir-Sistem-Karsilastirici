{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/products", "destination": "/api/products" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/products.js": {
      "includeFiles": "mock.json"
    }
  }
}
